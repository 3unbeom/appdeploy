require "net/http"
require "uri"

APP_IDENTIFIER = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)

def upload_to_r2(file:, key:, content_type: "application/octet-stream")
  bucket = ENV["R2_BUCKET"]
  sh("wrangler r2 object put #{bucket}/#{key} --file #{file} --content-type #{content_type}")
  "#{ENV['R2_PUBLIC_URL']}/#{key}"
end

def generate_manifest(ipa_url:, bundle_id:, version:, title:)
  {
    "items" => [{
      "assets"   => [{ "kind" => "software-package", "url" => ipa_url }],
      "metadata" => {
        "bundle-identifier" => bundle_id,
        "bundle-version"    => version,
        "kind"              => "software",
        "title"             => title,
      },
    }],
  }.to_plist
end

def notify_telegram(message:)
  token = ENV["TELEGRAM_BOT_TOKEN"]
  chat_id = ENV["TELEGRAM_CHAT_ID"]
  return unless token && chat_id

  uri = URI("https://api.telegram.org/bot#{token}/sendMessage")
  Net::HTTP.post_form(uri, chat_id: chat_id, text: message, parse_mode: "Markdown")
end

def certificate_name(match_type)
  ENV["sigh_#{APP_IDENTIFIER}_#{match_type}_certificate-name"]
end

def profile_name(match_type)
  ENV["sigh_#{APP_IDENTIFIER}_#{match_type}_profile-name"]
end

def generate_export_options(match_type)
  path = File.join(Dir.tmpdir, "ExportOptions.plist")
  File.write(path, {
    "method"               => lane_context[SharedValues::SIGH_PROFILE_TYPE],
    "signingStyle"         => "manual",
    "signingCertificate"   => certificate_name(match_type),
    "provisioningProfiles" => lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING],
  }.to_plist)
  path
end

IPA_PATH = "../../build/ios/ipa/*.ipa"

platform :ios do
  before_all do
    setup_ci
  end

  private_lane :setup_signing do |options|
    type = options[:type]
    match(
      type: type,
      readonly: true,
      clone_branch_directly: true,
    )
    update_code_signing_settings(
      path: "Runner.xcodeproj",
      targets: "Runner",
      build_configurations: "Release",
      code_sign_identity: certificate_name(type),
      profile_name: profile_name(type),
    )
  end

  lane :beta do
    type = "adhoc"
    setup_signing(type: type)
    sh("cd ../.. && flutter build ipa --export-options-plist=#{generate_export_options(type)}")
    ipa = File.expand_path(Dir.glob(IPA_PATH).first)
    version = YAML.load_file("../../pubspec.yaml")["version"].to_s.split("+").first
    ipa_key = "ios/#{APP_IDENTIFIER}/#{version}/#{File.basename(ipa)}"
    ipa_url = upload_to_r2(file: ipa, key: ipa_key)

    manifest = generate_manifest(ipa_url: ipa_url, bundle_id: APP_IDENTIFIER, version: version, title: APP_IDENTIFIER)
    manifest_path = File.join(Dir.tmpdir, "manifest.plist")
    File.write(manifest_path, manifest)
    manifest_key = "ios/#{APP_IDENTIFIER}/#{version}/manifest.plist"
    manifest_url = upload_to_r2(file: manifest_path, key: manifest_key, content_type: "application/xml")

    install_link = "itms-services://?action=download-manifest&url=#{manifest_url}"
    slack
    notify_telegram(message: "✅ *#{APP_IDENTIFIER}* iOS 베타 배포 완료\n#{install_link}")
  end

  lane :release do
    type = "appstore"
    setup_signing(type: type)
    build_number = latest_testflight_build_number + 1
    sh("cd ../.. && flutter build ipa --export-options-plist=#{generate_export_options(type)} --build-number=#{build_number}")
    deliver(
      ipa: File.expand_path(Dir.glob(IPA_PATH).first),
      app_version: YAML.load_file("../../pubspec.yaml")["version"].to_s.split("+").first,
      force: true,
      automatic_release: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: true,
      reject_if_possible: true,
    )
    slack
    notify_telegram(message: "✅ *#{APP_IDENTIFIER}* iOS 릴리스 배포 완료")
  end
end

error do |lane, exception|
  slack(message: exception.message, success: false)
  notify_telegram(message: "❌ *#{APP_IDENTIFIER}* iOS 배포 실패\n`#{exception.message}`")
end
