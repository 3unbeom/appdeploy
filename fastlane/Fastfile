# ── Setup ──────────────────────────────────────────────────

require 'json'
require 'plist'

PUBSPEC  = YAML.load_file("../pubspec.yaml")
APP_NAME = PUBSPEC["name"]
VERSION  = PUBSPEC["version"].to_s.split("+").first
IPA_PATH = "build/ios/ipa/#{APP_NAME}.ipa"

def generate_export_options(method:)
  plist = {
    "method"               => method,
    "signingStyle"         => "manual",
    "teamID"               => ENV["TEAM_ID"],
    "provisioningProfiles" => lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING],
  }

  path = File.join(Dir.tmpdir, "ExportOptions.plist")
  File.write(path, plist.to_plist)
  path
end

# ── Lanes ──────────────────────────────────────────────────

platform :ios do
  lane :beta do
    setup_ci
    match(type: "adhoc", readonly: true)
    export_plist = generate_export_options(method: "ad-hoc")
    sh("flutter build ipa --export-options-plist=#{export_plist}")
    firebase_app_distribution(
      ipa_path: IPA_PATH,
      groups: "testers",
      service_credentials_json_data: ENV["SUPPLY_JSON_KEY_DATA"],
    )
    slack
  end

  lane :deploy do
    setup_ci
    match(type: "appstore", readonly: true)
    build_number = latest_testflight_build_number + 1
    export_plist = generate_export_options(method: "app-store")
    sh("flutter build ipa --export-options-plist=#{export_plist} --build-number=#{build_number}")
    deliver(app_version: VERSION, ipa: IPA_PATH)
    slack
  end
end

platform :android do
  lane :deploy do
    sh("flutter build appbundle --build-number=#{google_play_track_version_codes.max + 1}")
    supply
    slack
  end
end

# ── Error ──────────────────────────────────────────────────

error do |lane, exception|
  slack(message: exception.message, success: false)
end
